{
  "name": "wipeit",
  "version": "1.0.0",
  "description": "Interactive node_modules cleaner CLI for macOS",
  "author": "Boopathy Ganesh K <boopathyganesh95@gmail.com>",
  "type": "module",
  "bin": {
    "wipeit": "./dist/index.js"
  },
  "scripts": {
